# Autostart applications
exec_always swaync
exec_always eww
exec_always /home/kostya/.config/sway/alternating_layouts.py 
exec_always dbus-update-activation-environment --systemd SWAYSOK XDG_SESSION_TYPE WAYLAND_DISPLAY DISPLAY XDG_CURRENT_DESKTOP SWAYSOCK I3SOCK XCURSOR_SIZE XCURSOR_THEME
exec_always dbus-update-actcvation-environment -all
exec_always dbus-launch
exec_always /usr/lib/xdg-desktop-portal -r
exec_always /home/kostya/.config/sway/pipewire-start.sh
exec_always killall waybar ; waybar 
exec_always blueman-applet
exec_always dicons1

seat * xcursor_theme catppuccin-macchiato-lavender-cursors 24

xwayland enable

# Keybindings configuration
set $mod Mod1
set $left h
set $down j
set $up k
set $right l
set $menu dmenu_path | wofi 
set $term alacritty

# workspace_layout tabbed
bindsym $mod+s layout tabbed
bindsym $mod+e layout toggle split


set $black #000000
set $gray1 #111111
set $gray2 #222222
set $gray3 #333333
set $gray4 #444444
set $gray5 #666666
set $gray6 #888888

set $red #ff5555
set $orange #ff9955
set $yellow #ffcc55
set $green #55cc55
set $cyan #55dddd
set $blue #4488ff
set $purple #cc66cc
set $pink #ff88cc

set $text #e0e0e0
set $subtext #b0b0b0
set $accent $blue

client.focused           $accent $black $text $accent $accent
client.focused_inactive  $gray3 $gray1 $subtext $gray3 $gray3
client.unfocused         $gray3 $gray1 $subtext $gray3 $gray3
client.urgent            $red $black $red $red $red
client.placeholder       $gray3 $gray1 $subtext $gray3 $gray3
client.background        $black

default_border pixel 2
titlebar_border_thickness 1
titlebar_padding 2 2

bindsym --to-code $mod+p exec /home/kostya/.config/sway/wallpaper_change.sh
bindsym --to-code $mod+Shift+p exec python3 /home/kostya/.config/waybar/themes/switch_theme.py


# Basic keybindings
bindsym $mod+Return exec $term
bindsym --to-code $mod+Shift+q kill
bindsym --to-code $mod+space exec $menu
bindsym --to-code $mod+y exec mercury
bindsym --to-code $mod+t exec export XDG_CURRENT_DESKTOP=gnome && ayugram
bindsym --to-code $mod+u exec yandex-music
bindsym $mod+Shift+c reload
bindsym $mod+Shift+e exec "swaymsg exit"

# Window navigation
bindsym $mod+$left focus left
bindsym $mod+$down focus down
bindsym $mod+$up focus up
bindsym $mod+$right focus right
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

# Window movement
bindsym $mod+Shift+$left move left
bindsym $mod+Shift+$down move down
bindsym $mod+Shift+$up move up
bindsym $mod+Shift+$right move right
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right
floating_modifier $mod normal

# Workspace management
bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
bindsym $mod+3 workspace number 3
bindsym $mod+4 workspace number 4
bindsym $mod+5 workspace number 5
bindsym $mod+6 workspace number 6
bindsym $mod+7 workspace number 7
bindsym $mod+8 workspace number 8
bindsym $mod+9 workspace number 9
bindsym $mod+0 workspace number 10
bindsym $mod+Mod4+Right workspace next
bindsym $mod+Mod4+Left workspace prev

# Move containers to workspaces
bindsym $mod+Shift+1 move container to workspace number 1
bindsym $mod+Shift+2 move container to workspace number 2
bindsym $mod+Shift+3 move container to workspace number 3
bindsym $mod+Shift+4 move container to workspace number 4
bindsym $mod+Shift+5 move container to workspace number 5
bindsym $mod+Shift+6 move container to workspace number 6
bindsym $mod+Shift+7 move container to workspace number 7
bindsym $mod+Shift+8 move container to workspace number 8
bindsym $mod+Shift+9 move container to workspace number 9
bindsym $mod+Shift+0 move container to workspace number 10

# Layout management
bindsym --to-code $mod+b splith
bindsym --to-code $mod+v splitv
bindsym --to-code $mod+f fullscreen
bindsym $mod+Shift+space floating toggle
bindsym $mod+space focus mode_toggle
bindsym $mod+a focus parent
bindsym $mod+Shift+minus move scratchpad
bindsym $mod+minus scratchpad show

# Resize mode
mode "resize" {
    bindsym $left resize shrink width 15px
    bindsym $down resize grow height 15px
    bindsym $up resize shrink height 15px
    bindsym $right resize grow width 15px
    bindsym Left resize shrink width 15px
    bindsym Down resize grow height 15px
    bindsym Up resize shrink height 15px
    bindsym Right resize grow width 15px
    bindsym Return mode "default"
    bindsym Escape mode "default"
    bindsym $mod+r mode "default"
}
bindsym $mod+r mode "resize"

# Screenshot keybindings
bindsym Print exec grim ~/Pictures/$(date +%s).png && notify-send "Скриншот сохранен."
bindsym $mod+Print exec grim -g "$(slurp)" ~/Pictures/screen-"$(date +%s)".png

# Input configuration
input * {
    xkb_layout us,ru
    xkb_options grp:win_space_toggle,compose:caps
}

input type:touchpad {
    tap enabled
    tap_button_map lrm
    # natural_scroll enabled
    dwt disabled
    xkb_options compose:caps
}

# SwayFX specific settings
shadows off
shadows_on_csd on
shadow_blur_radius 30
shadow_color #000000
blur enable
blur_xray enable
blur_passes 1
blur_radius 1
corner_radius 10
smart_corner_radius enable

# Window rules
for_window [tiling] border opacity 0.95
for_window [tiling] border pixel 2.5
for_window [floating] border opacity 0.95
for_window [floating] border pixel 2.5

for_window [app_id="thunar"] floating enable
for_window [class="feh"] floating enable, resize set 800 600
for_window [app_id="^(?!Alacritty$).*"] opacity 0.95
for_window [app_id="gnome-screenshot"] opacity 0.95
for_window [app_id="firefox"] opacity 0.95
for_window [app_id="floating-terminal"] floating enable

# Additional keybindings
bindsym --to-code $mod+o exec swaync-client -op
bindsym $mod+Ctrl+Up exec /home/kostya/.config/waybar/scripts/volumecontrol.sh up
bindsym $mod+Ctrl+Down exec /home/kostya/.config/waybar/scripts/volumecontrol.sh down
bindsym --to-code $mod+n exec playerctl next
bindsym --to-code $mod+m exec playerctl previous
bindsym --to-code $mod+k exec playerctl play-pause
bindsym F4 exec sh -c 'pactl set-source-mute @DEFAULT_SOURCE@ toggle && muted=$(pactl get-source-mute @DEFAULT_SOURCE@); if [[ $muted == *"yes"* ]]; then notify-send "Микрофон" "Отключен" -i audio-input-microphone-muted; else notify-send "Микрофон" "Включен" -i audio-input-microphone; fi'

bindsym XF86AudioPlay exec playerctl play-pause
bindsym XF86AudioNext exec playerctl next
bindsym XF86AudioPrev exec playerctl previous
bindsym XF86AudioStop exec playerctl stop

# Floating window rules
for_window [window_role="pop-up"] floating enable
for_window [window_role="bubble"] floating enable
for_window [window_role="dialog"] floating enable
for_window [window_type="dialog"] floating enable

# Include additional configuration files
include /etc/sway/config.d/*

